generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  myzaps   Zap[]
}

model Zap {
  id        String   @id @default(uuid())
  triggerId String
  trigger   Trigger?
  action    Action[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  zapRun    ZapRun[]
}

model Trigger {
  id                 String           @id @default(uuid())
  zapId              String           @unique
  availableTriggerId String
  type               AvailableTrigger @relation(fields: [availableTriggerId], references: [id])
  zap                Zap              @relation(fields: [zapId], references: [id])
}

model Action {
  id                String          @id @default(uuid())
  zapId             String
  availableActionId String
  zap               Zap             @relation(fields: [zapId], references: [id])
  type              AvailableAction @relation(fields: [availableActionId], references: [id])
  sortingOrder       Int              @default(0)
}

model AvailableTrigger {
  id      String    @id @default(uuid())
  name    String
  trigger Trigger[]
}

model AvailableAction {
  id     String   @id @default(uuid())
  name   String
  action Action[]
}

model ZapRun {
  id             String        @id @default(uuid())
  zapId          String
  metadata       Json
  zap            Zap           @relation(fields: [zapId], references: [id])
  createdAt      DateTime      @default(now())
  zapRunOutboxes ZapRunOutbox?
}

model ZapRunOutbox {
  id        String   @id @default(uuid())
  // No need to store zapId casue zapRun allready have it . 
  zapRunId  String   @unique
  zaprun    ZapRun   @relation(fields: [zapRunId], references: [id])
  createdAt DateTime @default(now())
}
